GEMINI_API_KEY="your_api_key_here"
GEMINI_MODEL="gemini-3.1-pro-preview"

# Protocol Toggles (set one to true)
USE_DOT=false
USE_DOH=false

# Client endpoint (match protocol)
# UDP:  127.0.0.1 (port 53535)
# DoT:  127.0.0.1 (port 853)
# DoH:  https://127.0.0.1/dns-query (port 443)
DNS_SERVER_ADDR=127.0.0.1
INSECURE_SKIP_VERIFY=true

# Server TLS Config (only needed for DoT/DoH)
TLS_CERT=cert.pem
TLS_KEY=key.pem
