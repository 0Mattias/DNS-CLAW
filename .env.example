GEMINI_API_KEY="your-api-key-here"
GEMINI_MODEL="gemini-3.1-pro-preview"

# Transport (pick one — set to true)
USE_DOT=false
USE_DOH=false

# Server address (must match transport)
#   UDP:  127.0.0.1
#   DoT:  127.0.0.1
#   DoH:  https://127.0.0.1/dns-query
DNS_SERVER_ADDR=127.0.0.1
INSECURE_SKIP_VERIFY=true

# TLS certs (DoT/DoH only — run ./generate_certs.sh)
TLS_CERT=cert.pem
TLS_KEY=key.pem
