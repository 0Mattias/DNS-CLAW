# ── LLM Provider ────────────────────────────────────────────────────
# Set one API key — the server auto-detects the provider.
# Or set LLM_PROVIDER explicitly: gemini | openai | anthropic | openrouter

# Gemini
# GEMINI_API_KEY="your-api-key-here"
# GEMINI_MODEL="gemini-2.5-flash"

# OpenAI
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-5.4"

# Anthropic (Claude)
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-sonnet-4-6"

# OpenRouter (any model — "openrouter/auto" picks the best)
# OPENROUTER_API_KEY="sk-or-..."
# OPENROUTER_MODEL="openrouter/auto"

# ── Encryption ──────────────────────────────────────────────────────
# AES-256-GCM payload encryption (recommended).
# Both client and server MUST use the same key.
# Generate: openssl rand -base64 32
# TUNNEL_PSK="your-secret-key-here"

# ── Transport ───────────────────────────────────────────────────────
# Default: UDP. Set ONE to true for encrypted transport.
# Port is auto-detected: UDP=53, DoT=853, DoH=443
# Only set SERVER_PORT if you need a non-standard port.
USE_DOT=false
USE_DOH=false

# Server address
#   UDP/DoT: 127.0.0.1
#   DoH:     https://127.0.0.1/dns-query
DNS_SERVER_ADDR=127.0.0.1
INSECURE_SKIP_VERIFY=true

# SERVER_PORT=53  (auto-detected from transport mode)

# TLS certs (DoT/DoH only — generated by setup.sh)
TLS_CERT=cert.pem
TLS_KEY=key.pem

# ── Custom system prompt (optional) ────────────────────────────────
# Override the default AI persona/instructions.
# SYSTEM_PROMPT="You are a helpful assistant."
